# API Keys (DO NOT COMMIT ACTUAL KEYS)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_PROJECT_ID=your_project_id_here
OPENAI_ORGANIZATION_ID=your_org_id_here
AZURE_COMPUTER_VISION_KEY=your_azure_vision_key_here
AZURE_COMPUTER_VISION_ENDPOINT=your_azure_vision_endpoint_here

# Production Settings
DEBUG=False
SECRET_KEY=your_django_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,your_domain.com

# Database Configuration
DATABASE_URL=sqlite:///db.sqlite3

# CORS and Security Settings
CORS_ALLOWED_ORIGINS=https://your_domain.com
CSRF_TRUSTED_ORIGINS=https://your_domain.com

# Session and Cookie Settings
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True 